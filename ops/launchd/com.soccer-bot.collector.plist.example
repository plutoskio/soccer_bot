<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.soccer-bot.collector</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/milo/Desktop/soccer_bot/.venv/bin/python</string>
    <string>/Users/milo/Desktop/soccer_bot/scripts/run_collector.py</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/milo/Desktop/soccer_bot</string>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>RunAtLoad</key>
  <false/>
  <key>StandardOutPath</key>
  <string>/Users/milo/Desktop/soccer_bot/logs/collector.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/milo/Desktop/soccer_bot/logs/collector.err.log</string>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
